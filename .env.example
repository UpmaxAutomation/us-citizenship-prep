# Site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://uscitizenshiptestprep.com

# Google Tag Manager (handles GA4, conversion tracking, remarketing)
# Get your GTM ID from https://tagmanager.google.com/
NEXT_PUBLIC_GTM_ID=

# Google Search Console verification
# Get your code from https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense publisher ID (e.g., ca-pub-1234567890)
# Get your ID from https://www.google.com/adsense/
NEXT_PUBLIC_ADSENSE_ID=

# Lead capture form endpoint (Mailchimp, ConvertKit, custom API, etc.)
# Leave empty to simulate success (for development)
NEXT_PUBLIC_LEAD_FORM_ACTION=
